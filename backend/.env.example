# Backend environment example
BACKEND_SERVICE_NAME="SKN28 Backend"
BACKEND_SERVICE_VERSION="0.1.0"
BACKEND_API_HOST="127.0.0.1"
BACKEND_API_PORT=8000
# 개발 중에는 true, 프로덕션에서는 반드시 false
BACKEND_RELOAD=false
# 프론트엔드 개발 서버 주소
BACKEND_CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'
BACKEND_LANGCHAIN_PROJECT=""

# OpenRouter API
# https://openrouter.ai/keys 에서 발급
BACKEND_OPENROUTER_API_KEY=""
BACKEND_OPENROUTER_MODEL="openai/gpt-oss-120b"
BACKEND_OPENROUTER_APP_TITLE="SKN28 Backend Agent"
BACKEND_OPENROUTER_APP_URL=""

# LLM
BACKEND_LLM_TEMPERATURE=0.2
BACKEND_LLM_TIMEOUT_MS=60000
BACKEND_LLM_MAX_RETRIES=2
BACKEND_LLM_REASONING_EFFORT="medium"

# RAG 서버
BACKEND_RAG_SEARCH_URL="http://127.0.0.1:8010/search"
BACKEND_RAG_SEARCH_TOP_K=5
BACKEND_RAG_SEARCH_QUERY_MAX_CHARS=500
BACKEND_RAG_SEARCH_TIMEOUT_MS=10000

# 세션 만료 시간 (초, 기본 3600 = 1시간)
BACKEND_SESSION_TTL_SECONDS=3600

# 요청 제한
BACKEND_RATE_LIMIT_ENABLED=true
BACKEND_RATE_LIMIT_REQUESTS=60
BACKEND_RATE_LIMIT_WINDOW_SECONDS=60

# Logging
BACKEND_LOG_LEVEL="INFO"
BACKEND_LOG_LLM_CONTEXT=true
